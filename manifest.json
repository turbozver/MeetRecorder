{
    "name": "Meet Recorder",
    "description": "Record Google Meet tab audio/video locally, with microphone mixed only while Meet mic is unmuted.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["activeTab", "tabs", "tabCapture", "offscreen", "downloads", "storage"],
    "host_permissions": ["https://meet.google.com/*"],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        },
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://meet.google.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
